    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx src/server/queue/worker-entry.ts",
    "worker:dev": "tsx watch src/server/queue/worker-entry.ts",
    "ssh:exec": "python scripts/ssh_exec.py"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@next/env": "15.5.13",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.44.0",
    "antd": "^6.3.3",
    "antd-mobile": "^5.42.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.7",
    "next": "15.5.13",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.13",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
